{
  "_comment": "将此 agents 配置合并到 Codespace 的 ~/.openclaw/openclaw.json 中",
  "agents": {
    "defaults": {
      "model": "openrouter/google/gemini-3-flash-preview",
      "subagents": {
        "maxSpawnDepth": 1,
        "maxConcurrent": 8
      }
    },
    "list": [
      {
        "id": "main",
        "name": "Stock Orchestrator",
        "default": true,
        "workspace": "~/.openclaw/workspace-main",
        "subagents": {
          "allowAgents": ["stock-technical", "stock-fundamental", "stock-sentiment"]
        },
        "skills": [],
        "tools": {
          "allow": ["sessions_spawn", "sessions_list", "sessions_history", "message"]
        }
      },
      {
        "id": "stock-technical",
        "name": "Technical Analyst",
        "workspace": "~/.openclaw/workspace-technical",
        "skills": [],
        "tools": {
          "allow": ["exec", "read", "write", "web_search", "web_fetch"]
        }
      },
      {
        "id": "stock-fundamental",
        "name": "Fundamental Analyst",
        "workspace": "~/.openclaw/workspace-fundamental",
        "skills": [],
        "tools": {
          "allow": ["exec", "read", "write", "web_search", "web_fetch"]
        }
      },
      {
        "id": "stock-sentiment",
        "name": "Sentiment Analyst",
        "workspace": "~/.openclaw/workspace-sentiment",
        "skills": [],
        "tools": {
          "allow": ["exec", "read", "write", "web_search", "web_fetch"]
        }
      }
    ]
  }
}
